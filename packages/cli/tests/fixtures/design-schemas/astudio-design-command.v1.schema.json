{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://design-studio.local/schemas/astudio-design-command.v1.schema.json",
  "title": "aStudio design command envelope",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "designKind": {
      "enum": [
        "astudio.design.lint.v1",
        "astudio.design.diff.v1",
        "astudio.design.export.v1",
        "astudio.design.checkBrand.v1",
        "astudio.design.init.v1",
        "astudio.design.migrate.v1",
        "astudio.design.doctor.v1",
        "astudio.design.prepare.v1",
        "astudio.design.components.v1",
        "astudio.design.coverage.v1",
        "astudio.design.proposeAbstraction.v1"
      ]
    },
    "prepareDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "designTokenRole": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "useFor"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "cssVariable": {
          "type": "string",
          "pattern": "^--[A-Za-z0-9_-]+$"
        },
        "useFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "avoidFor": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "designTokenContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "allowedRoles", "forbiddenTokenPatterns", "sourceRefs"],
      "properties": {
        "mode": {
          "const": "semantic-only"
        },
        "allowedRoles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/designTokenRole"
          }
        },
        "forbiddenTokenPatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "safetyClass", "reason"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "safetyClass": {
          "const": "read_only"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "packageScript": {
          "type": "string",
          "minLength": 1
        },
        "expectedOutcome": {
          "type": "string",
          "minLength": 1
        },
        "timeoutClass": {
          "enum": ["short", "medium", "long"]
        },
        "blockedByDefault": {
          "type": "boolean"
        },
        "ifFails": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prepareValidationCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "safetyClass",
        "reason",
        "packageScript",
        "expectedOutcome",
        "timeoutClass",
        "ifFails"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "safetyClass": {
          "const": "read_only"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "packageScript": {
          "type": "string",
          "minLength": 1
        },
        "expectedOutcome": {
          "type": "string",
          "minLength": 1
        },
        "timeoutClass": {
          "enum": ["short", "medium", "long"]
        },
        "blockedByDefault": {
          "type": "boolean"
        },
        "ifFails": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "prepareNextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "instruction", "evidenceRefs"],
      "allOf": [
        {
          "if": {
            "required": ["kind"],
            "properties": {
              "kind": {
                "not": {
                  "const": "implement"
                }
              }
            }
          },
          "then": {
            "required": ["reasonCode"],
            "properties": {
              "reasonCode": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "required": ["kind"],
            "properties": {
              "kind": {
                "const": "stop_for_missing_route"
              }
            }
          },
          "then": {
            "required": ["recoveryAction", "routeDiagnostics"],
            "properties": {
              "recoveryAction": {
                "enum": [
                  "create_route_candidate",
                  "use_existing_route",
                  "mark_exempt_with_reason",
                  "open_proposal"
                ]
              },
              "routeDiagnostics": {
                "$ref": "#/definitions/prepareRouteDiagnostics"
              }
            }
          }
        }
      ],
      "properties": {
        "kind": {
          "enum": [
            "implement",
            "stop_for_proposal",
            "stop_for_manual_decision",
            "stop_for_missing_route",
            "stop_for_validation_setup"
          ]
        },
        "reasonCode": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recoveryAction": {
          "enum": [
            "create_route_candidate",
            "use_existing_route",
            "mark_exempt_with_reason",
            "open_proposal"
          ]
        },
        "routeDiagnostics": {
          "$ref": "#/definitions/prepareRouteDiagnostics"
        }
      }
    },
    "prepareRouteDiagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protectedScopeMatched",
        "scopeSource",
        "unmatchedSurfacePattern",
        "closestRoutes",
        "candidateFilesToUpdate"
      ],
      "properties": {
        "protectedScopeMatched": {
          "type": "boolean"
        },
        "scopeSource": {
          "type": "string",
          "minLength": 1
        },
        "unmatchedSurfacePattern": {
          "type": "string",
          "minLength": 1
        },
        "closestRoutes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["routeId", "because", "confidence"],
            "properties": {
              "routeId": {
                "type": "string",
                "minLength": 1
              },
              "because": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "confidence": {
                "enum": ["low", "medium"]
              }
            }
          }
        },
        "candidateFilesToUpdate": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "prepareDoNotInvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["thing", "instead", "sourceRefs"],
      "properties": {
        "thing": {
          "type": "string",
          "minLength": 1
        },
        "instead": {
          "type": "string",
          "minLength": 1
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "routeConfidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "because"],
      "properties": {
        "level": {
          "enum": ["high", "medium", "low"]
        },
        "because": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "exampleUsageGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["copy", "doNotCopy", "proves", "maturity"],
      "properties": {
        "copy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "doNotCopy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maturity": {
          "enum": ["gold", "acceptable", "legacy", "deferred"]
        }
      }
    },
    "routeFallback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "reason"],
      "properties": {
        "component": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "routePreferredComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "importPath", "packageName"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "importPath": {
          "type": "string",
          "minLength": 1
        },
        "packageName": {
          "type": "string",
          "minLength": 1
        },
        "coverageName": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "componentLifecycleEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "lifecycle", "routing_tier", "notes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle": {
          "enum": ["canonical", "transitional", "deprecated"]
        },
        "routing_tier": {
          "type": "integer",
          "minimum": 0
        },
        "proposalRef": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "componentCoverageEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "upstream",
        "fallback",
        "status",
        "web_used",
        "tauri_used",
        "widget_used"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "upstream": {
          "type": ["string", "null"]
        },
        "fallback": {
          "type": ["string", "null"]
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "web_used": {
          "type": "boolean"
        },
        "tauri_used": {
          "type": "boolean"
        },
        "widget_used": {
          "type": "boolean"
        }
      }
    },
    "recommendedRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "need",
        "canonicalNeed",
        "aliases",
        "preferredComponent",
        "lifecycleStatus",
        "routeMaturity",
        "surfacePatterns",
        "useWhen",
        "requiredStates",
        "examples",
        "avoid",
        "fallbacks",
        "validationCommands",
        "sourceRefs",
        "lifecycleEntry",
        "coverageEntry",
        "matchedNeed",
        "matchedAlias",
        "confidence",
        "usageGuidance"
      ],
      "properties": {
        "need": {
          "type": "string",
          "minLength": 1
        },
        "canonicalNeed": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proposalRef": {
          "type": "string",
          "minLength": 1
        },
        "preferredComponent": {
          "$ref": "#/definitions/routePreferredComponent"
        },
        "lifecycleStatus": {
          "enum": ["canonical", "transitional"]
        },
        "routeMaturity": {
          "enum": ["enforced", "provisional"]
        },
        "surfacePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "useWhen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredStates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "avoid": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/routeFallback"
          }
        },
        "validationCommands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/prepareValidationCommand"
          }
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lifecycleEntry": {
          "$ref": "#/definitions/componentLifecycleEntry"
        },
        "coverageEntry": {
          "$ref": "#/definitions/componentCoverageEntry"
        },
        "matchedNeed": {
          "type": "string",
          "minLength": 1
        },
        "matchedAlias": {
          "type": ["string", "null"]
        },
        "confidence": {
          "$ref": "#/definitions/routeConfidence"
        },
        "usageGuidance": {
          "$ref": "#/definitions/exampleUsageGuidance"
        }
      }
    },
    "openDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "severity", "nextAction"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "enum": ["info", "warn", "error"]
        },
        "nextAction": {
          "enum": ["stop", "escalate", "diagnose"]
        }
      }
    },
    "preparePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ok",
        "safeForAutomaticImplementation",
        "nextAction",
        "resolvedDesignFile",
        "guidanceConfigPath",
        "designContractMode",
        "surfacePath",
        "surfaceScope",
        "surfaceKind",
        "recommendedRoutes",
        "designTokenContract",
        "doNotInvent",
        "requiredStates",
        "forbiddenPatterns",
        "relevantExamples",
        "validationCommands",
        "ruleManifestVersion",
        "rulePackVersion",
        "ruleSourceDigests",
        "sourceDigests",
        "coverageMatrixDigest",
        "componentLifecycleDigest",
        "wrapper-evidence",
        "final-plan-evidence",
        "openDecisions"
      ],
      "properties": {
        "kind": {
          "const": "astudio.design.prepare.v1"
        },
        "ok": {
          "type": "boolean"
        },
        "safeForAutomaticImplementation": {
          "type": "boolean"
        },
        "nextAction": {
          "$ref": "#/definitions/prepareNextAction"
        },
        "resolvedDesignFile": {
          "type": "string",
          "minLength": 1
        },
        "guidanceConfigPath": {
          "type": "string",
          "minLength": 1
        },
        "designContractMode": {
          "enum": ["legacy", "design-md"]
        },
        "surfacePath": {
          "type": "string",
          "minLength": 1
        },
        "surfaceScope": {
          "enum": ["protected", "warn", "exempt", "unknown"]
        },
        "surfaceKind": {
          "type": "string",
          "minLength": 1
        },
        "recommendedRoutes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/recommendedRoute"
          }
        },
        "designTokenContract": {
          "$ref": "#/definitions/designTokenContract"
        },
        "doNotInvent": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/prepareDoNotInvent"
          }
        },
        "requiredStates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbiddenPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relevantExamples": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "validationCommands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/prepareValidationCommand"
          }
        },
        "ruleManifestVersion": {
          "type": "string",
          "minLength": 1
        },
        "rulePackVersion": {
          "type": "string",
          "minLength": 1
        },
        "ruleSourceDigests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/prepareDigest"
          }
        },
        "sourceDigests": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/prepareDigest"
          }
        },
        "coverageMatrixDigest": {
          "$ref": "#/definitions/prepareDigest"
        },
        "componentLifecycleDigest": {
          "$ref": "#/definitions/prepareDigest"
        },
        "wrapper-evidence": {
          "type": "string",
          "minLength": 1
        },
        "final-plan-evidence": {
          "type": "string",
          "minLength": 1
        },
        "openDecisions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/openDecision"
          }
        }
      }
    }
  },
  "required": ["schema", "meta", "summary", "status", "data", "errors"],
  "properties": {
    "schema": {
      "const": "astudio.command.v1"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "version", "timestamp", "outputMode"],
      "properties": {
        "tool": {
          "const": "astudio"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "outputMode": {
          "enum": ["json", "plain"]
        },
        "request_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "parent_id": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["success", "warn", "error"]
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "$ref": "#/definitions/designKind"
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          },
          "hint": {
            "type": "string",
            "minLength": 1
          },
          "did_you_mean": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "fix_suggestion": {
            "type": "string",
            "minLength": 1
          },
          "recovery": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "fix_suggestion": {
                "type": "string",
                "minLength": 1
              },
              "nextCommand": {
                "type": "object",
                "additionalProperties": false,
                "required": ["argv"],
                "properties": {
                  "argv": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string"
                    }
                  },
                  "cwd": {
                    "type": "string",
                    "minLength": 1
                  },
                  "env": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                }
              },
              "recoveryUnavailableReason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "type": "object",
        "properties": {
          "status": {
            "enum": ["success", "warn"]
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "kind": {
                "$ref": "#/definitions/designKind"
              }
            },
            "required": ["kind"]
          },
          "errors": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "status": {
            "const": "error"
          }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "errors": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "kind": {
                "const": "astudio.design.prepare.v1"
              }
            },
            "required": ["kind"]
          }
        },
        "required": ["data"]
      },
      "then": {
        "properties": {
          "data": {
            "$ref": "#/definitions/preparePayload"
          }
        }
      }
    }
  ]
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "types": ["node"],
    "paths": {
      "@design-studio/runtime": ["../runtime/dist/index.d.ts"],
      "@design-studio/tokens": ["../tokens/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "**/*.stories.*",
    "**/*.mdx",
    "**/*.test.*",
    "**/*.figmaConnect.*",
    "src/testing/**",
    "src/dev/**",
    "src/dev.ts",
    "src/storybook/_holding/**"
  ]
}

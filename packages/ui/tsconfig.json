{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "types": ["node"]
  },
  "references": [
    { "path": "../runtime/tsconfig.build.json" },
    { "path": "../tokens/tsconfig.build.json" }
  ],
  "include": ["src/**/*"],
  "exclude": [
    "**/*.stories.*",
    "**/*.mdx",
    "**/*.test.*",
    "**/*.figmaConnect.*",
    "src/testing/**",
    "src/dev/**",
    "src/dev.ts",
    "src/storybook/_holding/**"
  ]
}

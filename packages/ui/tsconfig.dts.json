{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@design-studio/runtime": ["packages/runtime/dist/index.d.ts"],
      "@design-studio/tokens": ["packages/tokens/dist/index.d.ts"],
      "@design-studio/skill-ingestion": ["packages/skill-ingestion/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.stories.*", "**/*.mdx", "**/*.test.*", "**/*.figmaConnect.*", "src/testing/**"]
}

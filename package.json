{
  "name": "astudio-sdk-ready",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm -C platforms/web/apps/web dev",
    "dev:storybook": "pnpm -C platforms/web/apps/storybook dev",
    "dev:widgets": "pnpm -C packages/widgets dev",
    "build": "node scripts/build-pipeline.mjs",
    "build:web": "node scripts/build-pipeline.mjs --platforms web",
    "build:incremental": "node scripts/build-pipeline.mjs",
    "build:clean": "node scripts/build-pipeline.mjs --no-incremental",
    "build:widget": "pnpm -C platforms/web/apps/web build:widget",
    "build:widgets": "pnpm -C packages/widgets build",
    "build:lib": "pnpm -C packages/ui build && pnpm -C packages/runtime build && pnpm -C packages/tokens build && pnpm -C packages/json-render build",
    "build:astudio-tokens": "pnpm -C packages/tokens build",
    "build:astudio-ui": "pnpm -C packages/ui build",
    "build:astudio-icons": "pnpm -C packages/astudio-icons build",
    "build:astudio-json-render": "pnpm -C packages/json-render build",
    "build:astudio": "pnpm build:astudio-tokens && pnpm build:astudio-ui && pnpm build:astudio-icons && pnpm build:astudio-json-render",
    "design-system-guidance:build": "pnpm -C packages/design-system-guidance build",
    "design-system-guidance:type-check": "pnpm -C packages/design-system-guidance type-check",
    "design-system-guidance:check": "pnpm -C packages/design-system-guidance run build && node packages/design-system-guidance/dist/cli.js check .",
    "design-system-guidance:check:ci": "pnpm -C packages/design-system-guidance run build && node packages/design-system-guidance/dist/cli.js check . --ci",
    "design-system-guidance:ratchet": "pnpm -C packages/design-system-guidance run build && node scripts/policy/run-guidance-ratchet.mjs",
    "release:guidance:validate": "pnpm design-system-guidance:type-check && pnpm design-system-guidance:build && pnpm design-system-guidance:check:ci",
    "generate:tokens": "pnpm -C packages/tokens generate && pnpm dlx @biomejs/biome@2.3.11 format --write packages/tokens/src/colors.ts packages/tokens/src/spacing.ts packages/tokens/src/typography.ts packages/tokens/src/radius.ts packages/tokens/src/shadows.ts packages/tokens/src/sizes.ts packages/tokens/docs/outputs/manifest.json",
    "ds:matrix:generate": "node --import tsx scripts/generate-coverage-matrix.ts",
    "ds:matrix:check": "node --import tsx scripts/generate-coverage-matrix.ts --check",
    "ds:alignment:stamp": "node scripts/stamp-upstream-alignment.mjs",
    "ds:astudio:sync-versions": "pnpm -C packages/tokens exec tsx ../../scripts/sync-astudio-versions.ts",
    "sync:versions": "node scripts/version-sync.mjs",
    "sync:versions:check": "node scripts/version-sync.mjs --check",
    "generated-source:check": "node scripts/check-generated-sources.mjs",
    "agent-design:boundaries": "node scripts/check-agent-design-boundaries.mjs",
    "agent-design:boundaries:self-test": "node scripts/check-agent-design-boundaries.mjs --self-test",
    "tracked-ignored:check": "node scripts/check-tracked-ignored-artifacts.mjs",
    "tracked-ignored:check:self-test": "node scripts/check-tracked-ignored-artifacts.mjs --self-test",
    "harness:pr-pipeline": "python3 scripts/harness_pr_pipeline.py",
    "validation-prototype:build": "pnpm -C packages/validation-prototype build",
    "validation-prototype:analyze": "pnpm -C packages/validation-prototype analyze",
    "validate:tokens": "pnpm -C packages/tokens validate",
    "tokens:validate": "pnpm validate:tokens",
    "mcp:dev": "pnpm -C platforms/mcp dev",
    "mcp:start": "pnpm -C platforms/mcp start",
    "mcp:inspector": "pnpm -C platforms/mcp inspector",
    "mcp:test": "pnpm -C platforms/mcp test",
    "mcp:test:contract": "pnpm -C platforms/mcp test:contract",
    "mcp:test:jsonrpc": "pnpm -C platforms/mcp test:jsonrpc",
    "mcp:test:cli": "pnpm -C platforms/mcp test:cli",
    "mcp:test:inspector-ui": "pnpm -C platforms/mcp test:inspector-ui",
    "storybook:dev": "pnpm -C platforms/web/apps/storybook dev",
    "storybook:build": "pnpm -C platforms/web/apps/storybook build",
    "storybook:test": "pnpm -C platforms/web/apps/storybook test",
    "storybook:test:browser": "pnpm -C platforms/web/apps/storybook test:browser",
    "storybook:test:coverage": "pnpm -C platforms/web/apps/storybook test:coverage",
    "test": "pnpm -C packages/ui test",
    "test:agent-browser": "node scripts/agent-browser/run.mjs",
    "test:agent-browser:ci": "node scripts/agent-browser/run-ci.mjs",
    "test:agent-browser:storybook": "node scripts/agent-browser/storybook-run.mjs",
    "test:agent-browser:storybook:ci": "node scripts/agent-browser/storybook-run-ci.mjs",
    "test:e2e:web": "pnpm -C packages/ui build:visual && pnpm exec playwright test -c platforms/web/apps/web/playwright.config.ts",
    "test:exemplar-evaluation": "node scripts/policy/run-exemplar-evaluation.mjs",
    "test:exemplar-evaluation:list": "node scripts/policy/run-exemplar-evaluation.mjs --list",
    "test:exemplar-evaluation:update": "node scripts/policy/run-exemplar-evaluation.mjs --update-snapshots",
    "test:a11y:widgets": "pnpm -C packages/ui build:visual && pnpm exec playwright test -c packages/widgets/playwright.a11y.config.ts",
    "test:a11y:widgets:ci": "pnpm exec playwright test -c packages/widgets/playwright.a11y.config.ts",
    "test:mcp-contract": "node --test platforms/mcp/tests/tool-contract.test.mjs",
    "migrate:imports": "pnpm -C packages/tokens exec tsx ../../scripts/migration/migrate-imports.ts",
    "test:visual:web": "node scripts/run-playwright-suite.mjs web-visual",
    "test:visual:update": "node scripts/run-playwright-suite.mjs web-visual --update-snapshots",
    "test:cross-platform": "node scripts/build-pipeline.mjs --skip-tests=false",
    "test:build-pipeline": "npx vitest run scripts/build-pipeline.test.js --config scripts/vitest.config.js",
    "test:visual:storybook": "node scripts/run-playwright-suite.mjs storybook-visual",
    "test:visual:storybook:update": "node scripts/run-playwright-suite.mjs storybook-visual --update-snapshots",
    "test:drift": "node scripts/test-drift.mjs",
    "test:token-drift": "node scripts/test-token-drift.mjs",
    "test:runtime": "pnpm -C packages/runtime build && node --test packages/runtime/tests/host-adapter.test.mjs",
    "test:template-registry": "pnpm exec vitest run scripts/template-registry-*.test.mjs --config scripts/vitest.config.js",
    "test:theme-propagation": "pnpm exec vitest run scripts/theme-propagation.test.mjs --config scripts/vitest.config.js",
    "test:web:property": "pnpm test:theme-propagation && pnpm exec vitest run platforms/web/apps/web/tests/template-preview-resilience.test.mjs --config scripts/vitest.config.js",
    "bundle:analyze": "node ./scripts/bundle-size.mjs",
    "bundle:monitor": "node ./scripts/bundle-size-monitor.mjs",
    "bundle:monitor:strict": "node ./scripts/bundle-size-monitor.mjs --strict",
    "bundle:monitor:json": "node ./scripts/bundle-size-monitor.mjs --json",
    "argos:upload": "pnpm exec -- argos upload ./screenshots",
    "astudio": "pnpm -C packages/cli run start",
    "astudio:dev": "pnpm -C packages/cli run dev",
    "astudio:build": "pnpm -C packages/cli run build",
    "test:watch": "pnpm -C packages/ui test:watch",
    "test:coverage": "pnpm -C packages/ui test:coverage",
    "test:tokens": "pnpm -C packages/tokens test",
    "test:astudio-icons": "pnpm -C packages/astudio-icons generate && pnpm -C packages/astudio-icons test",
    "test:embed": "pnpm build:widget && node ./platforms/mcp/scripts/smoke.mjs",
    "test:policy": "node scripts/policy/run.mjs",
    "lint:compliance": "node ./scripts/compliance.mjs",
    "onboarding:parity:check": "node scripts/check-onboarding-parity.mjs",
    "onboarding:outcome:check": "node scripts/check-onboarding-outcomes.mjs",
    "onboarding:check": "pnpm onboarding:parity:check && pnpm onboarding:outcome:check",
    "doc:lint": "pnpm docs:lint",
    "lint": "pnpm dlx @biomejs/biome@2.3.11 check .",
    "format": "pnpm dlx @biomejs/biome@2.3.11 format . --write",
    "format:check": "pnpm dlx @biomejs/biome@2.3.11 format .",
    "new:component": "node ./scripts/new-component.mjs",
    "publish:astudio": "pnpm -C packages/tokens publish --access restricted --no-git-checks && pnpm -C packages/ui publish --access restricted --no-git-checks && pnpm -C packages/astudio-icons publish --access restricted --no-git-checks",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "codestyle:validate": "bash scripts/validate-codestyle.sh",
    "secrets:staged": "bash scripts/check-staged-secrets.sh",
    "docs:style:changed": "bash scripts/check-doc-style.sh",
    "test:related": "bash scripts/check-related-tests.sh",
    "semgrep:changed": "bash scripts/check-semgrep-changed.sh",
    "prepare": "if command -v prek >/dev/null; then node scripts/setup-git-hooks.js; else echo \"prek unavailable; skipping git hook install\"; fi",
    "docs:lint": "vale sync && fd -t f -e md -E .agent -E _tools -E reports -E node_modules -E .wrangler -E .build -E .swiftpm -E AGENTS.md -E CLAUDE.md -E references -X vale && node scripts/check-doc-links.mjs",
    "check": "pnpm lint && pnpm docs:lint && pnpm typecheck && pnpm test",
    "typecheck": "pnpm -r --filter '!@design-studio/effects' run type-check",
    "agent-design:build": "pnpm -C packages/agent-design-engine build",
    "agent-design:type-check": "pnpm -C packages/agent-design-engine type-check",
    "agent-design:test": "pnpm -C packages/agent-design-engine test",
    "agent-design:lint": "node packages/cli/dist/index.js design lint --file DESIGN.md --json"
  },
  "devDependencies": {
    "@argos-ci/cli": "^3.0.6",
    "@argos-ci/playwright": "^1.7.0",
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.27.1",
    "@modelcontextprotocol/inspector": "^0.19.0",
    "@openai/apps-sdk-ui": "0.2.1",
    "@playwright/test": "^1.58.2",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "agent-browser": "0.23.0",
    "ajv": "^8.18.0",
    "concurrently": "^9.2.1",
    "fast-check": "^4.5.3",
    "hono": "^4.12.12",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "storybook": "^10.2.10",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
      }
    },
    "overrides": {
      "storybook": "10.2.10",
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "@modelcontextprotocol/sdk@<1.24.0": ">=1.24.0",
      "@modelcontextprotocol/sdk@<1.26.0": ">=1.26.0",
      "react-router@>=7.0.0 <=7.11.0": ">=7.12.0",
      "react-router@>=7.0.0 <7.12.0": ">=7.12.0",
      "react-router@>=7.0.0 <7.9.6": ">=7.9.6",
      "react-router@>=7.0.0 <=7.8.2": ">=7.9.0",
      "hono@<4.12.7": ">=4.12.7",
      "@hono/node-server@<1.19.10": ">=1.19.10",
      "basic-ftp@<5.2.0": ">=5.2.0",
      "diff@<8.0.3": ">=8.0.3",
      "fast-xml-parser@<5.5.7": ">=5.5.7",
      "undici": ">=7.24.0",
      "tar@<=7.5.2": ">=7.5.3",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "lodash@<=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "express-rate-limit": "8.2.2",
      "axios@<=1.13.4": ">=1.13.5",
      "svgo@<3.3.3": ">=3.3.3",
      "rollup@<4.59.0": ">=4.59.0",
      "ajv@>=7.0.0 <8.18.0": ">=8.18.0",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "playwright": "1.58.2",
      "playwright-core": "1.58.2",
      "vite": "7.3.2",
      "convict@<=6.2.4": ">=6.2.5",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0"
    },
    "publicHoistPattern": [
      "@storybook/*",
      "storybook"
    ],
    "onlyBuiltDependencies": [
      "sharp",
      "workerd"
    ],
    "ignoredBuiltDependencies": [
      "agent-browser"
    ]
  }
}
